FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key

# Database Configuration
# For Supabase (recommended for Vercel):
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres?sslmode=require
# For local development:
# DATABASE_URL=postgresql://synclearn:synclearn@localhost:5432/synclearn

# Redis Configuration
# For Vercel Redis:
REDIS_URL=redis://:your-token@your-vercel-redis-url.upstash.io
# For local development:
# REDIS_URL=redis://localhost:6379/0

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
# Optional: Use alternative provider like Azure OpenAI or GitHub Models
# OPENAI_BASE_URL=https://models.inference.ai.azure.com
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AWS S3 Configuration (for file uploads: slides, videos, thumbnails)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
# Optional: Custom S3 endpoint (for S3-compatible services like MinIO)
# AWS_S3_ENDPOINT_URL=https://minio.example.com

# Temporary upload directory for processing files
TEMP_UPLOAD_DIR=/tmp/synclearn_uploads
