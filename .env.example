# Copy this file to .env and fill values before running Docker.
# Compose will automatically load variables from .env in the project root.

# Required for API-based ASR transcription fallback (recommended)
OPENAI_API_KEY=

# Optional: custom OpenAI-compatible endpoint
OPENAI_BASE_URL=

# Optional: model overrides
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: local whisper model cache path inside container
# WHISPER_DOWNLOAD_ROOT=/app/.cache/whisper

# Optional: corporate/network proxy for outbound HTTPS from Docker containers
# HTTP_PROXY=http://host:port
# HTTPS_PROXY=http://host:port
# NO_PROXY=localhost,127.0.0.1,db
