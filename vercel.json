{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build && mkdir -p ../backend/static_frontend && cp -r build/* ../backend/static_frontend/",
  "builds": [
    {
      "src": "backend/run.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/run.py"
    },
    {
      "src": "/health",
      "dest": "backend/run.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "backend/run.py"
    },
    {
      "src": "/(.*)",
      "dest": "backend/run.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production"
  }
}
