{
  "name": "synclearn",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:frontend": "cd frontend && npm install",
    "build:frontend": "cd frontend && npm run build",
    "copy:frontend": "mkdir -p backend/static_frontend && cp -r frontend/build/* backend/static_frontend/",
    "build": "npm run install:frontend && npm run build:frontend && npm run copy:frontend",
    "dev": "cd frontend && npm install && npm start",
    "vercel-build": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1",
    "axios": "^1.7.9"
  }
}
