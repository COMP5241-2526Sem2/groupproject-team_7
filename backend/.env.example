FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key

# Database Configuration - Supabase
# For Supabase (recommended for Vercel), use SUPABASE_URL and SUPABASE_PUBLISHABLE_KEY:
SUPABASE_URL=<SUBSTITUTE_SUPABASE_URL>
SUPABASE_PUBLISHABLE_KEY=<SUBSTITUTE_SUPABASE_PUBLISHABLE_KEY>
# Optional: For direct PostgreSQL connection via Supabase
# SUPABASE_DB_PASSWORD=your-supabase-db-password

# Redis Configuration
# For Vercel Redis:
REDIS_URL=redis://:your-token@your-vercel-redis-url.upstash.io
# For local development:
# REDIS_URL=redis://localhost:6379/0

# LLM Configuration (GitHub Models preferred)
GITHUB_TOKEN=your-github-token-with-models-access
# Optional override (defaults to https://models.github.ai/inference when GITHUB_TOKEN is set)
# GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference

# Optional compatibility variables (if using non-GitHub OpenAI-compatible providers)
# OPENAI_API_KEY=your-provider-api-key
# OPENAI_BASE_URL=https://models.inference.ai.azure.com
# OPENAI_CHAT_MODEL=openai/gpt-4.1
# OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small

# AWS S3 Configuration (for file uploads: slides, videos, thumbnails)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
# Optional: Custom S3 endpoint (for S3-compatible services like MinIO)
# AWS_S3_ENDPOINT_URL=https://minio.example.com

# Temporary upload directory for processing files
TEMP_UPLOAD_DIR=/tmp/synclearn_uploads
